# Backend
APP_ENV=local
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/agrodoc
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# Domains
API_DOMAIN=api.domain.com
APP_DOMAIN=app.domain.com
ADMIN_DOMAIN=admin.domain.com

# Storage / CORS
FILES_STORAGE_ROOT=/data/files
FILES_STORAGE_BACKEND=local
# For S3 / MinIO: set FILES_STORAGE_BACKEND=s3, S3_BUCKET, S3_REGION, optional S3_ENDPOINT_URL
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Auth (JWT)
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
# Set true only for local dev without login (sends X-User-Roles / X-Account-UUID)
AUTH_BYPASS_HEADERS=false

# После `alembic upgrade head` в dev БД появляются сиды: e2e_admin/testpass1, admin/admin (см. README; не для production)
